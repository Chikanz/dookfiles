#!/bin/bash
set -euo pipefail

# squashvid - Convert H.264 videos to H.265/HEVC at equivalent perceived quality
# Uses Apple VideoToolbox hardware encoding by default (GPU accelerated)
# Falls back to libx265 software encoding with --software flag
#
# Usage: squashvid <file_extension>
# Example: squashvid mp4
#          squashvid mkv --quality 60 --software

# --- Configuration ---
# Hardware mode (VideoToolbox) settings
VT_QUALITY=63              # -q:v value for VideoToolbox (1-100, higher = better quality, ~65 matches CRF 23 x264)
BITRATE_RATIO=0.55         # Target this fraction of source bitrate (0.55 = 55%, good for equivalent HEVC quality)

# Software mode (libx265) settings
SW_PRESET="medium"         # x265 preset
CRF_OFFSET=4               # Added to estimated source CRF for x265 equivalence
FALLBACK_X265_CRF=28       # Used when source CRF can't be determined

# General
OUTPUT_SUFFIX="_hevc"       # Appended to filename before extension
DRY_RUN=false
USE_SOFTWARE=false
SINGLE_FILE=""

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

# --- Helpers ---
log()  { echo -e "${GREEN}[squashvid]${NC} $*"; }
warn() { echo -e "${YELLOW}[squashvid]${NC} $*"; }
err()  { echo -e "${RED}[squashvid]${NC} $*" >&2; }

usage() {
    echo -e "${BOLD}squashvid${NC} - Convert H.264 videos to H.265/HEVC at equivalent quality"
    echo -e "Uses Apple VideoToolbox (GPU) by default for fast hardware encoding."
    echo ""
    echo -e "${BOLD}Usage:${NC}"
    echo "  squashvid <file_extension> [options]"
    echo "  squashvid <file_path> [options]"
    echo ""
    echo -e "${BOLD}Examples:${NC}"
    echo "  squashvid mp4                          # GPU encode all .mp4 files"
    echo "  squashvid video.mp4                    # GPU encode a single file"
    echo "  squashvid /path/to/clip.mov            # GPU encode a single file by path"
    echo "  squashvid mkv --quality 70             # Higher quality GPU encode"
    echo "  squashvid mp4 --ratio 0.5              # Target 50% of source bitrate"
    echo "  squashvid mp4 --software --preset slow  # Software encode (slower, better compression)"
    echo "  squashvid mp4 --dry-run                # Preview without encoding"
    echo ""
    echo -e "${BOLD}GPU Options (default):${NC}"
    echo "  --quality <1-100>   VideoToolbox quality (default: 65, higher = better)"
    echo "  --ratio <0.0-1.0>  Target bitrate as fraction of source (default: 0.55)"
    echo ""
    echo -e "${BOLD}Software Options:${NC}"
    echo "  --software          Use libx265 CPU encoding (slower, better compression)"
    echo "  --preset <preset>   x265 preset (default: medium)"
    echo "  --offset <n>        CRF offset for x264→x265 mapping (default: 4)"
    echo "  --fallback-crf <n>  CRF when source quality unknown (default: 28)"
    echo ""
    echo -e "${BOLD}General Options:${NC}"
    echo "  --suffix <suffix>   Output filename suffix (default: _hevc)"
    echo "  --dry-run           Show what would be done without encoding"
    echo "  --help              Show this help message"
    exit 0
}

check_deps() {
    for cmd in ffmpeg ffprobe; do
        if ! command -v "$cmd" &>/dev/null; then
            err "$cmd is required but not installed."
            err "Install with: brew install ffmpeg"
            exit 1
        fi
    done
}

check_videotoolbox() {
    if ! ffmpeg -hide_banner -encoders 2>/dev/null | grep -q hevc_videotoolbox; then
        err "hevc_videotoolbox encoder not available in your ffmpeg build."
        err "Install a build with VideoToolbox: brew install ffmpeg"
        err "Or use --software for CPU encoding."
        exit 1
    fi
}

get_video_bitrate() {
    local file="$1"
    local bitrate

    # Try stream-level video bitrate first
    bitrate=$(ffprobe -v quiet -select_streams v:0 -show_entries stream=bit_rate \
        -of default=noprint_wrappers=1:nokey=1 "$file" 2>/dev/null || true)

    # Fall back to format-level bitrate
    if [[ -z "$bitrate" || "$bitrate" == "N/A" ]]; then
        bitrate=$(ffprobe -v quiet -show_entries format=bit_rate \
            -of default=noprint_wrappers=1:nokey=1 "$file" 2>/dev/null || true)
    fi

    # Fall back to computing from file size and duration
    if [[ -z "$bitrate" || "$bitrate" == "N/A" ]]; then
        local filesize duration
        filesize=$(stat -f%z "$file" 2>/dev/null || stat -c%s "$file" 2>/dev/null)
        duration=$(ffprobe -v quiet -show_entries format=duration \
            -of default=noprint_wrappers=1:nokey=1 "$file" 2>/dev/null || true)
        if [[ -n "$duration" && "$duration" != "N/A" ]]; then
            bitrate=$(echo "scale=0; $filesize * 8 / $duration" | bc 2>/dev/null || true)
        fi
    fi

    if [[ -z "$bitrate" || "$bitrate" == "N/A" ]]; then
        echo ""
    else
        echo "$bitrate"
    fi
}

# Estimate source CRF for software encoding mode
estimate_source_crf() {
    local file="$1"

    # Check metadata for stored CRF
    local encoded_crf
    encoded_crf=$(ffprobe -v quiet -show_entries format_tags=crf \
        -of default=noprint_wrappers=1:nokey=1 "$file" 2>/dev/null || true)
    if [[ -n "$encoded_crf" && "$encoded_crf" != "N/A" ]]; then
        printf "%.0f" "$encoded_crf"
        return
    fi

    # Try x264 encoder settings string (macOS-compatible sed instead of grep -P)
    local encoder_settings
    encoder_settings=$(ffprobe -v quiet -show_streams -of json "$file" 2>/dev/null \
        | sed -n 's/.*crf=\([0-9.]*\).*/\1/p' | head -1 || true)
    if [[ -n "$encoder_settings" ]]; then
        printf "%.0f" "$encoder_settings"
        return
    fi

    # Fallback: bits-per-pixel heuristic
    local width height fps bitrate
    width=$(ffprobe -v quiet -select_streams v:0 -show_entries stream=width \
        -of default=noprint_wrappers=1:nokey=1 "$file")
    height=$(ffprobe -v quiet -select_streams v:0 -show_entries stream=height \
        -of default=noprint_wrappers=1:nokey=1 "$file")
    fps=$(ffprobe -v quiet -select_streams v:0 -show_entries stream=r_frame_rate \
        -of default=noprint_wrappers=1:nokey=1 "$file")
    bitrate=$(get_video_bitrate "$file")

    if [[ -z "$bitrate" || -z "$width" || -z "$height" || -z "$fps" ]]; then
        echo ""
        return
    fi

    local fps_val
    fps_val=$(echo "scale=4; $fps" | bc 2>/dev/null || echo "30")

    local bpp
    bpp=$(echo "scale=6; $bitrate / ($width * $height * $fps_val)" | bc 2>/dev/null)

    if [[ -z "$bpp" ]]; then
        echo ""
        return
    fi

    # CRF ≈ 23 - 8 * log2(bpp / 0.07)
    local estimated_crf
    estimated_crf=$(echo "scale=2; 23 - 8 * (l($bpp / 0.07) / l(2))" | bc -l 2>/dev/null)

    if [[ -z "$estimated_crf" ]]; then
        echo ""
        return
    fi

    echo "$estimated_crf" | awk '{ v=$1; if(v<10) v=10; if(v>40) v=40; printf "%.0f", v }'
}

get_video_codec() {
    local file="$1"
    ffprobe -v quiet -select_streams v:0 -show_entries stream=codec_name \
        -of default=noprint_wrappers=1:nokey=1 "$file" 2>/dev/null
}

get_video_info() {
    local file="$1"
    local width height duration bitrate
    width=$(ffprobe -v quiet -select_streams v:0 -show_entries stream=width \
        -of default=noprint_wrappers=1:nokey=1 "$file" 2>/dev/null)
    height=$(ffprobe -v quiet -select_streams v:0 -show_entries stream=height \
        -of default=noprint_wrappers=1:nokey=1 "$file" 2>/dev/null)
    duration=$(ffprobe -v quiet -show_entries format=duration \
        -of default=noprint_wrappers=1:nokey=1 "$file" 2>/dev/null)
    bitrate=$(get_video_bitrate "$file")

    local dur_formatted="?"
    if [[ -n "$duration" && "$duration" != "N/A" ]]; then
        dur_formatted=$(printf "%.0f" "$duration" | awk '{m=int($1/60); s=int($1%60); printf "%dm%02ds", m, s}')
    fi

    local br_formatted="?"
    if [[ -n "$bitrate" && "$bitrate" != "N/A" ]]; then
        br_formatted=$(echo "$bitrate" | awk '{printf "%.1f Mbps", $1/1000000}')
    fi

    echo "${width}x${height}, ${dur_formatted}, ${br_formatted}"
}

format_size() {
    local bytes="$1"
    if (( bytes >= 1073741824 )); then
        echo "$(echo "scale=2; $bytes / 1073741824" | bc) GB"
    elif (( bytes >= 1048576 )); then
        echo "$(echo "scale=1; $bytes / 1048576" | bc) MB"
    else
        echo "$(echo "scale=0; $bytes / 1024" | bc) KB"
    fi
}

format_bitrate() {
    local bps="$1"
    if (( bps >= 1000000 )); then
        echo "$(echo "scale=1; $bps / 1000000" | bc) Mbps"
    else
        echo "$(echo "scale=0; $bps / 1000" | bc) kbps"
    fi
}

# --- Parse arguments ---
if [[ $# -lt 1 ]]; then
    usage
fi

EXT=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --software)     USE_SOFTWARE=true; shift ;;
        --quality)      VT_QUALITY="$2"; shift 2 ;;
        --ratio)        BITRATE_RATIO="$2"; shift 2 ;;
        --preset)       SW_PRESET="$2"; shift 2 ;;
        --offset)       CRF_OFFSET="$2"; shift 2 ;;
        --fallback-crf) FALLBACK_X265_CRF="$2"; shift 2 ;;
        --suffix)       OUTPUT_SUFFIX="$2"; shift 2 ;;
        --dry-run)      DRY_RUN=true; shift ;;
        --help|-h)      usage ;;
        -*)             err "Unknown option: $1"; usage ;;
        *)
            if [[ -z "$EXT" && -z "$SINGLE_FILE" ]]; then
                if [[ -f "$1" ]]; then
                    SINGLE_FILE="$1"
                else
                    EXT="${1#.}"
                fi
            else
                err "Unexpected argument: $1"
                usage
            fi
            shift
            ;;
    esac
done

if [[ -z "$EXT" && -z "$SINGLE_FILE" ]]; then
    err "No file extension or file path specified."
    usage
fi

check_deps

if [[ "$USE_SOFTWARE" == false ]]; then
    check_videotoolbox
    log "Encoder: ${BOLD}hevc_videotoolbox${NC} (GPU accelerated)"
    log "Quality: ${BOLD}${VT_QUALITY}/100${NC}, bitrate ratio: ${BOLD}${BITRATE_RATIO}${NC}"
else
    log "Encoder: ${BOLD}libx265${NC} (software, preset: ${SW_PRESET})"
    log "CRF offset: ${BOLD}+${CRF_OFFSET}${NC}"
fi
echo ""

# --- Find matching files ---
if [[ -n "$SINGLE_FILE" ]]; then
    EXT="${SINGLE_FILE##*.}"
    files=( "$SINGLE_FILE" )
    log "Single file mode: ${BOLD}${SINGLE_FILE}${NC}"
else
    shopt -s nullglob nocaseglob
    files=( *."$EXT" )
    shopt -u nullglob nocaseglob

    if [[ ${#files[@]} -eq 0 ]]; then
        err "No .$EXT files found in the current directory."
        exit 1
    fi

    log "Found ${BOLD}${#files[@]}${NC} .$EXT file(s) in $(pwd)"
fi
echo ""

# --- Scan and plan ---
declare -a to_convert=()
declare -a encode_params=()
declare -a encode_methods=()

for file in "${files[@]}"; do
    basename_no_ext="${file%.*}"

    # Skip already-converted files
    if [[ "$basename_no_ext" == *"$OUTPUT_SUFFIX" ]]; then
        echo -e "  ${DIM}⊘ Skipping ${file} (already converted)${NC}"
        continue
    fi

    output_file="${basename_no_ext}${OUTPUT_SUFFIX}.${EXT}"
    if [[ -f "$output_file" ]]; then
        echo -e "  ${DIM}⊘ Skipping ${file} (output already exists)${NC}"
        continue
    fi

    codec=$(get_video_codec "$file")

    if [[ "$codec" != "h264" ]]; then
        if [[ "$codec" == "hevc" || "$codec" == "h265" ]]; then
            echo -e "  ${DIM}⊘ Skipping ${file} (already HEVC)${NC}"
        else
            warn "Skipping ${file} (codec: ${codec}, not H.264)"
        fi
        continue
    fi

    info=$(get_video_info "$file")
    filesize=$(stat -f%z "$file" 2>/dev/null || stat -c%s "$file" 2>/dev/null)
    size_fmt=$(format_size "$filesize")

    if [[ "$USE_SOFTWARE" == false ]]; then
        # --- GPU mode: compute target bitrate ---
        src_bitrate=$(get_video_bitrate "$file")

        if [[ -n "$src_bitrate" ]]; then
            target_bitrate=$(echo "scale=0; $src_bitrate * $BITRATE_RATIO / 1" | bc 2>/dev/null)
            target_fmt=$(format_bitrate "$target_bitrate")
            src_fmt_br=$(format_bitrate "$src_bitrate")
            method="src ${src_fmt_br} × ${BITRATE_RATIO} → ${target_fmt}, q:v ${VT_QUALITY}"
            param="${target_bitrate}"
        else
            # Can't determine bitrate — use quality-only mode
            method="quality-only q:v ${VT_QUALITY} (source bitrate unknown)"
            param="0"
        fi

        echo -e "  ${CYAN}▶${NC} ${BOLD}${file}${NC}"
        echo -e "    ${info} | ${size_fmt}"
        echo -e "    → VideoToolbox: ${BOLD}${method}${NC}"
    else
        # --- Software mode: compute target CRF ---
        src_crf=$(estimate_source_crf "$file")

        if [[ -n "$src_crf" ]]; then
            x265_crf=$(( src_crf + CRF_OFFSET ))
            method="estimated src CRF ${src_crf} + offset ${CRF_OFFSET}"
        else
            x265_crf=$FALLBACK_X265_CRF
            method="fallback (could not determine source quality)"
        fi

        (( x265_crf < 10 )) && x265_crf=10
        (( x265_crf > 42 )) && x265_crf=42
        param="$x265_crf"

        echo -e "  ${CYAN}▶${NC} ${BOLD}${file}${NC}"
        echo -e "    ${info} | ${size_fmt}"
        echo -e "    → libx265 CRF ${BOLD}${x265_crf}${NC} ${DIM}(${method})${NC}"
    fi

    to_convert+=("$file")
    encode_params+=("$param")
    encode_methods+=("$method")
done

echo ""

if [[ ${#to_convert[@]} -eq 0 ]]; then
    log "Nothing to convert."
    exit 0
fi

if [[ "$DRY_RUN" == true ]]; then
    warn "Dry run — no files will be encoded."
    exit 0
fi

echo ""

# --- Encode ---
success=0
failed=0
total_saved=0

for i in "${!to_convert[@]}"; do
    file="${to_convert[$i]}"
    param="${encode_params[$i]}"
    basename_no_ext="${file%.*}"
    output_file="${basename_no_ext}${OUTPUT_SUFFIX}.${EXT}"

    if [[ "$USE_SOFTWARE" == false ]]; then
        # --- GPU encode with VideoToolbox ---
        log "Encoding ${BOLD}${file}${NC} → ${BOLD}${output_file}${NC} (VideoToolbox, q:v ${VT_QUALITY})"

        ffmpeg_args=(
            -i "$file"
            -c:v hevc_videotoolbox
            -q:v "$VT_QUALITY"
            -tag:v hvc1
        )

        # Add bitrate cap if we determined one
        if [[ "$param" != "0" ]]; then
            ffmpeg_args+=( -b:v "$param" )
        fi

        ffmpeg_args+=(
            -c:a copy
            -c:s copy
            -map 0
            -movflags +faststart
            -y
            "$output_file"
        )
    else
        # --- Software encode with libx265 ---
        log "Encoding ${BOLD}${file}${NC} → ${BOLD}${output_file}${NC} (CRF ${param}, preset ${SW_PRESET})"

        ffmpeg_args=(
            -i "$file"
            -c:v libx265
            -crf "$param"
            -preset "$SW_PRESET"
            -tag:v hvc1
            -c:a copy
            -c:s copy
            -map 0
            -movflags +faststart
            -y
            "$output_file"
        )
    fi

    if ffmpeg "${ffmpeg_args[@]}" 2>&1 | tail -1; then
        src_size=$(stat -f%z "$file" 2>/dev/null || stat -c%s "$file" 2>/dev/null)
        dst_size=$(stat -f%z "$output_file" 2>/dev/null || stat -c%s "$output_file" 2>/dev/null)
        saved=$(( src_size - dst_size ))
        pct=$(echo "scale=1; $saved * 100 / $src_size" | bc 2>/dev/null || echo "?")

        src_fmt=$(format_size "$src_size")
        dst_fmt=$(format_size "$dst_size")

        if (( saved > 0 )); then
            log "${GREEN}✓${NC} ${file}: ${src_fmt} → ${dst_fmt} (${GREEN}-${pct}%${NC})"
            total_saved=$(( total_saved + saved ))
        else
            warn "✓ ${file}: ${src_fmt} → ${dst_fmt} (${RED}grew by ${pct#-}%${NC})"
        fi
        (( success++ ))
    else
        err "✗ Failed to encode ${file}"
        rm -f "$output_file"
        (( failed++ ))
    fi

    echo ""
done

# --- Summary ---
echo -e "${BOLD}────────────────────────────────${NC}"
log "Done! ${GREEN}${success} succeeded${NC}, ${RED}${failed} failed${NC}"
if (( total_saved > 0 )); then
    log "Total space saved: ${BOLD}$(format_size $total_saved)${NC}"
fi
